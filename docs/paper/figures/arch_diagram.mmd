    E --> F["Executor\nExecution Plan → Results"]

    F --> G["LLM Adapter"]
    F --> H["Memory Store"]
    F --> I["RAG Store"]

    G --> J(["OpenRouter / Claude CLI"])
    H --> K(["SQLite\n(.spl/memory.db)"])
    I --> L(["FAISS / ChromaDB\n(.spl/vectors)"])

